// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum OrderStatus {
  PLACED
  CONFIRMED
  ON_HOLD
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  COD
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  RECEIVED
  REFUNDED
  REJECTED
}

enum RefundStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// CORE MODELS
// ============================================

model Category {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  imageUrl String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories Subcategory[]
  products      Product[]

  @@index([isActive])
  @@map("categories")
}

model Subcategory {
  id       String  @id @default(uuid())
  name     String
  slug     String
  imageUrl String?
  isActive Boolean @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
  @@map("subcategories")
}

model Product {
  id          String  @id @default(uuid())
  name        String
  description String?
  isFeatured  Boolean @default(false)
  featuredImageUrl String?
  isActive    Boolean @default(true)

  categoryId    String
  subcategoryId String

  category    Category    @relation(fields: [categoryId], references: [id])
  subcategory Subcategory @relation(fields: [subcategoryId], references: [id])

  skus   Sku[]
  images ProductImage[]
  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([isActive, isFeatured])
  @@map("products")
}

model ProductImage {
  id        String @id @default(uuid())
  imageUrl  String
  sortOrder Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_images")
}

model Sku {
  id      String @id @default(uuid())
  skuCode String @unique

  productId String
  product   Product @relation(fields: [productId], references: [id])

  size     String?
  weight   String?
  material String?
  color    String?

  mrp          Decimal
  sellingPrice Decimal
  festivePrice Decimal?
  gstPercent   Decimal

  stockQuantity Int
  isCodAllowed  Boolean @default(true)
  isActive      Boolean @default(true)

  countryOfOrigin     String
  manufacturerName    String
  manufacturerAddress String
  sellerName          String
  sellerAddress       String
  sellerPincode       String

  images     SkuImage[]
  orderItems OrderItem[]
  cartItems  CartItem[]
  reviews    Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("skus")
}

model SkuImage {
  id        String @id @default(uuid())
  imageUrl  String
  sortOrder Int    @default(0)

  skuId String
  sku   Sku    @relation(fields: [skuId], references: [id])

  @@index([skuId])
  @@map("sku_images")
}

// ============================================
// CUSTOMER & ADDRESS
// ============================================

model Customer {
  id    String @id @default(uuid())
  name  String
  email String @unique
  phone String

  addresses    Address[]
  orders       Order[]
  sessions     CustomerSession[]
  cart         Cart?
  couponUsages CouponUsage[]
  reviews      Review[]

  createdAt DateTime @default(now())

  @@index([phone])
  @@map("customers")
}

model Address {
  id    String @id @default(uuid())
  name  String
  phone String

  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean @default(false)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("addresses")
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String
  otpHash   String
  purpose   String   @default("LOGIN") // SIGNUP | LOGIN - default for backward compatibility if needed, though we will set it explicitly
  payload   Json?
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, purpose, createdAt])
  @@map("otp_verifications")
}

model CustomerSession {
  id         String   @id @default(uuid())
  customerId String
  tokenHash  String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([tokenHash])
  @@map("customer_sessions")
}

// ============================================
// ORDERS (IMMUTABLE CORE)
// ============================================

model Order {
  id          String @id @default(uuid())
  orderNumber String @unique

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  addressSnapshot Json
  shippingInfo    Json?

  status        OrderStatus
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus

  subtotalAmount Decimal
  gstAmount      Decimal
  codFee         Decimal
  totalAmount    Decimal

  orderItems  OrderItem[]
  payments    Payment[]
  refunds     Refund[]
  couponUsage CouponUsage?

  couponCode     String?
  discountAmount Decimal @default(0)

  placedAt    DateTime  @default(now())
  confirmedAt DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?

  @@index([placedAt])
  @@index([customerId, placedAt])
  @@map("orders")
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  skuId String
  sku   Sku    @relation(fields: [skuId], references: [id])

  skuSnapshot Json

  quantity     Int
  pricePerUnit Decimal
  gstPercent   Decimal
  totalPrice   Decimal

  // Coupon discount allocation (post-tax). Stored for refund accuracy and UI.
  discountAmount   Decimal @default(0)
  netTotalPrice    Decimal?
  netPricePerUnit  Decimal?

  return Return?
  review Review?

  @@index([orderId])
  @@index([skuId])
  @@map("order_items")
}

// ============================================
// PAYMENTS, RETURNS & REFUNDS
// ============================================

model Payment {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  provider         String
  reference        String?
  gatewayPaymentId String? // Razorpay payment id (pay_...)

  amount Decimal
  status PaymentStatus

  createdAt DateTime @default(now())

  @@index([reference])
  @@index([orderId])
  @@map("payments")
}

model Return {
  id          String    @id @default(uuid())
  orderItemId String    @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  reason       String
  customerNote String?
  status       ReturnStatus

  images ReturnImage[]

  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?

  @@index([status])
  @@index([requestedAt])
  @@map("returns")
}

model ReturnImage {
  id       String @id @default(uuid())
  imageUrl String

  returnId String
  return   Return @relation(fields: [returnId], references: [id])

  @@index([returnId])
  @@map("return_images")
}

model Refund {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  amount    Decimal
  status    RefundStatus
  reference String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([orderId])
  @@index([reference])
  @@map("refunds")
}

// ============================================
// ADMIN
// ============================================

model Admin {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  role         String  @default("ADMIN")
  isActive     Boolean @default(true)

  reviewedReviews Review[]

  createdAt DateTime @default(now())

  @@map("admins")
}

// ============================================
// CART (STATE ONLY)
// ============================================

model Cart {
  id         String     @id @default(uuid())
  customerId String     @unique
  customer   Customer   @relation(fields: [customerId], references: [id])
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id       String @id @default(uuid())
  cartId   String
  skuId    String
  quantity Int

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  sku  Sku  @relation(fields: [skuId], references: [id])

  @@unique([cartId, skuId])
  @@map("cart_items")
}

// ============================================
// COUPONS & PROMO CODES
// ============================================

model Coupon {
  id                    String       @id @default(uuid())
  code                  String       @unique
  description           String?
  discountType          DiscountType
  discountValue         Decimal
  minOrderAmount        Decimal?
  maxDiscount           Decimal?
  usageLimit            Int?
  usageLimitPerCustomer Int          @default(1)
  usageCount            Int          @default(0)
  isActive              Boolean      @default(true)
  startsAt              DateTime     @default(now())
  expiresAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerUses CouponUsage[]

  @@index([createdAt])
  @@map("coupons")
}

model CouponUsage {
  id         String   @id @default(uuid())
  couponId   String
  customerId String
  orderId    String   @unique
  usedAt     DateTime @default(now())

  coupon   Coupon   @relation(fields: [couponId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])

  @@unique([couponId, customerId, orderId])
  @@map("coupon_usages")
}

// ============================================
// REVIEWS (MODERATED PUBLIC FEED)
// ============================================

model Review {
  id String @id @default(uuid())

  orderItemId String @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  // Stored denormalized to make product listing/query faster.
  productId String
  product   Product @relation(fields: [productId], references: [id])

  skuId String?
  sku   Sku? @relation(fields: [skuId], references: [id])

  rating Int

  title   String?
  comment String?

  status          ReviewStatus @default(PENDING)
  reviewedByAdminId String?
  reviewedByAdmin   Admin? @relation(fields: [reviewedByAdminId], references: [id])

  rejectionReason String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, status, createdAt])
  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@map("reviews")
}
